# Django
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=clinic.settings.local

# Database
DATABASE_URL=postgres://clinic:clinic@db:5432/clinic

# Celery broker — points to LocalStack SQS locally, real SQS in production
CELERY_BROKER_URL=sqs://test:test@localstack:4566

# JWT
JWT_ACCESS_TOKEN_MINUTES=60
JWT_REFRESH_TOKEN_DAYS=7

# AWS (only needed when running against real SQS — in production IRSA handles this)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
SQS_QUEUE_NAME=clinic-tasks

# Email (console prints to terminal locally, SES in production)
DEFAULT_FROM_EMAIL=noreply@liman.clinic
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# SMS (console logs to terminal locally, sns uses AWS SNS in production)
SMS_BACKEND=console
